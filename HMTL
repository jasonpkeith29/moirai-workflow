    function renderReviewQuestions() {
      const root = document.getElementById('questionsBoard');
      reviewQuestionGroups.forEach((group, index) => {
        const wrapper = document.createElement('section');
        wrapper.className = 'question-accordion';
        const questions = group.questions.map((question) => `<li>${question}</li>`).join('');
        wrapper.innerHTML = `
          <button class="question-toggle" type="button" aria-expanded="false">
            <span class="question-chevron">›</span>
            <span class="question-title">${group.title}</span>
            <span class="question-count">${group.questions.length} questions</span>
          </button>
          <div class="question-panel">
            <div class="question-context">${group.context}</div>
            <ul class="review-question-list">${questions}</ul>
          </div>
        `;
        const toggle = wrapper.querySelector('.question-toggle');
        toggle.addEventListener('click', () => {
          const isOpen = wrapper.classList.toggle('open');
          toggle.setAttribute('aria-expanded', String(isOpen));
        });
        if (index === 0) {
          wrapper.classList.add('open');
          toggle.setAttribute('aria-expanded', 'true');
        }
        root.appendChild(wrapper);
      });
    }

