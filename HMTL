<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Moirai Workflow Comparison</title>
  <style>
    :root {
      --page-bg: #f8fafc;
      --surface: #ffffff;
      --text-main: #0f172a;
      --text-muted: #64748b;
      --text-soft: #94a3b8;
      --border: #e2e8f0;
      --automation-bg: #ecfeff;
      --automation-border: #67e8f9;
      --manual-border: #fdba74;
      --new-border: #93c5fd;
      --shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
      --orange: #ea580c;
      --blue: #2563eb;
      --indigo: #4f46e5;
      --teal: #0f766e;
      --slate: #1e293b;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--page-bg);
      color: var(--text-main);
    }
    .page {
      max-width: 1360px;
      margin: 0 auto;
      min-height: 100vh;
      padding: 24px;
    }
    .header { margin-bottom: 24px; }
    .eyebrow {
      display: inline-block;
      margin-bottom: 8px;
      padding: 4px 8px;
      border-radius: 999px;
      background: #e0f2fe;
      color: #0369a1;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .header h1 {
      margin: 0;
      font-size: 24px;
      font-weight: 700;
      line-height: 1.2;
    }
    .header p {
      margin: 6px 0 0;
      color: var(--text-muted);
      font-size: 13px;
      line-height: 1.5;
      max-width: 1000px;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 22px;
    }
    .summary-card,
    .workflow-card,
    .persona-journey-card,
    .merge-card,
    .process-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .summary-card {
      padding: 14px 16px;
    }
    .summary-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 6px;
    }
    .summary-value {
      font-size: 14px;
      font-weight: 700;
      color: var(--text-main);
      line-height: 1.45;
    }

    .section-title {
      margin: 28px 0 12px;
      font-size: 18px;
      font-weight: 700;
    }
    .section-subtitle {
      margin: -4px 0 14px;
      color: var(--text-muted);
      font-size: 13px;
      line-height: 1.5;
      max-width: 1020px;
    }

    .workflow-header,
    .persona-header,
    .merge-header,
    .process-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--border);
      background: #f8fafc;
      flex-wrap: wrap;
    }
    .card-title {
      font-size: 15px;
      font-weight: 700;
    }
    .header-note {
      margin-left: auto;
      font-size: 12px;
      color: var(--text-muted);
    }
    .badges {
      margin-left: auto;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .badge {
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .badge.manual { background: #ffedd5; color: #9a3412; }
    .badge.automation { background: #cffafe; color: #155e75; }
    .badge.high { background: #dcfce7; color: #166534; }
    .badge.stronger { background: #dbeafe; color: #1d4ed8; }
    .badge.persona { background: #e0e7ff; color: #4338ca; }

    .workflow-steps,
    .merge-steps {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: 10px;
      padding: 16px;
      align-items: stretch;
    }
    .workflow-step,
    .merge-step,
    .journey-step {
      position: relative;
      background: #ffffff;
      border: 1px solid var(--border);
      border-top: 4px solid var(--step-accent);
      border-radius: 10px;
      padding: 12px;
    }
    .workflow-step.current {
      background: linear-gradient(180deg, #fff7ed 0%, #ffffff 100%);
      min-height: 196px;
    }
    .workflow-step:not(:last-child)::after,
    .merge-step:not(:last-child)::after,
    .journey-step:not(:last-child)::after {
      content: "→";
      position: absolute;
      right: -12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-soft);
      font-size: 20px;
      font-weight: 700;
      z-index: 2;
    }
    .step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 999px;
      background: var(--step-accent);
      color: #ffffff;
      font-size: 11px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .step-name {
      font-size: 13px;
      font-weight: 700;
      line-height: 1.35;
      margin-bottom: 6px;
    }
    .step-copy {
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-main);
    }
    .step-tag {
      display: inline-block;
      width: fit-content;
      margin-top: auto;
      padding: 4px 7px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      background: #ecfeff;
      color: #155e75;
      border: 1px solid #67e8f9;
    }
    .step-tag.manual {
      background: #fff1e6;
      color: #9a3412;
      border: 1px solid #fdba74;
    }

    .cascade-flow {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
      margin-top: 8px;
    }
    .cascade-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--border);
      background: #f8fafc;
      flex-wrap: wrap;
    }
    .cascade-body {
      padding: 18px;
      background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    }
    .entry-lanes {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      position: relative;
    }
    .entry-lane {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .entry-lane-card,
    .shared-step {
      position: relative;
      background: #ffffff;
      border: 1px solid var(--border);
      border-top: 4px solid var(--step-accent);
      border-radius: 10px;
      padding: 12px;
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04);
    }
    .entry-lane-card {
      min-height: 176px;
      background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
    }
    .entry-title {
      font-size: 13px;
      font-weight: 800;
      line-height: 1.35;
      margin-bottom: 6px;
    }
    .entry-copy {
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-main);
    }
    .entry-tag,
    .shared-tag {
      display: inline-block;
      width: fit-content;
      margin-top: auto;
      padding: 4px 7px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      background: #ecfeff;
      color: #155e75;
      border: 1px solid #67e8f9;
    }
    .merge-hub {
      max-width: 520px;
      margin: 34px auto 0;
      padding: 13px 16px;
      border-radius: 12px;
      background: #ecfeff;
      border: 1px solid #67e8f9;
      color: #155e75;
      text-align: center;
      font-size: 12px;
      line-height: 1.5;
      font-weight: 800;
      position: relative;
    }
    .merge-hub::before {
      content: "";
      position: absolute;
      left: 50%;
      top: -34px;
      width: 1px;
      height: 34px;
      background: #94a3b8;
    }
    .merge-hub::after {
      content: "↓";
      position: absolute;
      left: 50%;
      bottom: -26px;
      transform: translateX(-50%);
      color: var(--text-soft);
      font-size: 20px;
      font-weight: 800;
    }
    .entry-lanes::after {
      content: "";
      position: absolute;
      left: calc(12.5% + 7px);
      right: calc(12.5% + 7px);
      bottom: -18px;
      height: 1px;
      background: #94a3b8;
    }
    .entry-lane::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -18px;
      width: 1px;
      height: 18px;
      background: #94a3b8;
    }
    .shared-flow {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: 10px;
      margin-top: 42px;
      align-items: stretch;
    }
    .shared-step {
      min-height: 170px;
      background: linear-gradient(180deg, #ecfeff 0%, #ffffff 100%);
    }
    .shared-step:not(:last-child)::after {
      content: "→";
      position: absolute;
      right: -12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-soft);
      font-size: 20px;
      font-weight: 800;
      z-index: 2;
    }
    .step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 999px;
      background: var(--step-accent);
      color: #ffffff;
      font-size: 11px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .step-name {
      font-size: 13px;
      font-weight: 700;
      line-height: 1.35;
      margin-bottom: 6px;
    }
    .step-copy {
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-main);
    }
    .publish-split {
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px dashed #94a3b8;
    }
    .publish-split-title {
      text-align: center;
      color: var(--text-muted);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 12px;
    }
    .publish-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      align-items: stretch;
    }
    .publish-card {
      position: relative;
      display: flex;
      flex-direction: column;
      border: 1px solid var(--border);
      border-top: 5px solid var(--publish-accent);
      border-radius: 12px;
      background: #ffffff;
      padding: 14px;
      min-height: 190px;
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04);
    }
    .publish-card.preprod {
      background: linear-gradient(180deg, #f0fdfa 0%, #ffffff 100%);
    }
    .publish-card.prod {
      background: linear-gradient(180deg, #eef2ff 0%, #ffffff 100%);
    }
    .publish-title {
      font-size: 14px;
      font-weight: 800;
      margin-bottom: 6px;
      color: var(--text-main);
    }
    .publish-copy {
      font-size: 12px;
      line-height: 1.55;
      color: var(--text-main);
      margin-bottom: 10px;
    }
    .publish-list {
      margin: 0;
      padding-left: 16px;
      font-size: 11px;
      line-height: 1.5;
      color: var(--text-main);
    }
    .publish-list li + li {
      margin-top: 4px;
    }
    .promotion-note {
      margin-top: 12px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid #c4b5fd;
      background: #f5f3ff;
      color: #4c1d95;
      font-size: 12px;
      line-height: 1.5;
      font-weight: 700;
      text-align: center;
    }

    .flow-footnote {
      margin-top: 16px;
      padding: 12px 14px;
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text-muted);
      font-size: 12px;
      line-height: 1.5;
    }

    .process-board {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-top: 8px;
    }
    .process-grid {
      display: grid;
      grid-template-columns: 1.02fr 1.02fr 0.96fr;
      gap: 0;
    }
    .process-cell {
      padding: 14px 16px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .process-grid .process-cell:nth-child(3n) {
      border-right: none;
    }
    .process-cell.current {
      background: linear-gradient(180deg, #fff7ed 0%, #ffffff 100%);
      border-top: 4px solid var(--manual-border);
    }
    .process-cell.future {
      background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
      border-top: 4px solid var(--new-border);
    }
    .process-cell.automation {
      background: linear-gradient(180deg, var(--automation-bg) 0%, #ffffff 100%);
      border-top: 4px solid var(--automation-border);
    }
    .cell-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin-bottom: 8px;
    }
    .step-list,
    .automation-list {
      margin: 0;
      padding-left: 16px;
      font-size: 12px;
      line-height: 1.55;
      color: var(--text-main);
    }
    .step-list li + li,
    .automation-list li + li {
      margin-top: 5px;
    }
    .step-highlight {
      display: inline-block;
      margin-top: 8px;
      padding: 6px 8px;
      border-radius: 8px;
      font-size: 11px;
      font-weight: 600;
      line-height: 1.45;
    }
    .step-highlight.manual {
      background: #fff1e6;
      color: #9a3412;
      border: 1px solid #fdba74;
    }
    .step-highlight.future {
      background: #e8f1ff;
      color: #1d4ed8;
      border: 1px solid #93c5fd;
    }
    .step-highlight.auto {
      background: #ecfeff;
      color: #155e75;
      border: 1px solid #67e8f9;
    }
    .questions-board {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 8px;
    }
    .question-accordion {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .question-toggle {
      width: 100%;
      border: 0;
      background: #f8fafc;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      text-align: left;
      color: var(--text-main);
      font-family: inherit;
    }
    .question-toggle:hover {
      background: #f1f5f9;
    }
    .question-title {
      font-size: 14px;
      font-weight: 800;
    }
    .question-count {
      margin-left: auto;
      padding: 4px 8px;
      border-radius: 999px;
      background: #e0f2fe;
      color: #0369a1;
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      white-space: nowrap;
    }
    .question-chevron {
      color: var(--text-muted);
      font-size: 16px;
      font-weight: 900;
      transition: transform 0.15s ease;
    }
    .question-accordion.open .question-chevron {
      transform: rotate(90deg);
    }
    .question-panel {
      display: none;
      padding: 0 16px 16px;
      border-top: 1px solid var(--border);
    }
    .question-accordion.open .question-panel {
      display: block;
    }
    .question-context {
      margin: 12px 0;
      padding: 10px 12px;
      border-radius: 10px;
      background: #f8fafc;
      color: var(--text-muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .review-question-list {
      margin: 0;
      padding-left: 18px;
      font-size: 12px;
      line-height: 1.55;
      color: var(--text-main);
    }
    .review-question-list li + li {
      margin-top: 6px;
    }

    .footer {
      text-align: center;
      color: #94a3b8;
      font-size: 12px;
      margin-top: 18px;
    }


    /* Align all pill/tag containers to a consistent baseline within each card. */
    .workflow-step,
    .entry-lane-card,
    .shared-step,
    .process-cell {
      display: flex;
      flex-direction: column;
    }
    .step-tag,
    .entry-tag,
    .shared-tag,
    .step-highlight {
      margin-top: auto;
      align-self: flex-start;
    }
    .step-copy,
    .entry-copy,
    .publish-copy,
    .step-list,
    .automation-list {
      margin-bottom: 12px;
    }

    @media (max-width: 1260px) {
      .summary-grid,
      .workflow-steps,
      .entry-lanes,
      .shared-flow,
      .publish-grid,
      .process-grid {
        grid-template-columns: 1fr;
      }
      .workflow-step:not(:last-child)::after,
      .shared-step:not(:last-child)::after {
        display: none;
      }
      .process-grid .process-cell {
        border-right: none;
      }
    }
    @media (max-width: 720px) {
      .page { padding: 16px; }
      .summary-grid { grid-template-columns: 1fr; }
      .header-note,
      .badges { margin-left: 0; }
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="header">
      <div class="eyebrow">Workflow Comparison</div>
      <h1>Current ADW Process vs. New Moirai Process</h1>
      <p>This view focuses on workflow structure and the operating-model shift from a manual, human-coordinated ADW process to a more automated Moirai process. The new workflow now shows distinct entry paths for each user persona and then makes the point where those paths converge into a shared governed workflow.</p>
    </header>

    <section class="summary-grid" aria-label="Executive summary metrics">
      <div class="summary-card">
        <div class="summary-label">Current State</div>
        <div class="summary-value">Human-coordinated, review-heavy, and spread across Jira, Bitbucket, Confluence, metadata tables, admin steps, and Airflow execution.</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Target State</div>
        <div class="summary-value">Intent-driven workflow with tailored entry paths, automated validation, generated DAGs, standard quality gates, and explicit publication flow.</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Efficiency Outlook</div>
        <div class="summary-value">Likely 30% to 60% faster for standard work with 50% to 80% fewer repetitive manual execution steps.</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Persona Value</div>
        <div class="summary-value">Shows clearly that the new process can support low-friction analysts, advanced builders, and downstream consumers without forcing everyone through the same manual workflow.</div>
      </div>
    </section>

    <h2 class="section-title">Existing Product Analytics ADW Workflow</h2>
    <p class="section-subtitle">This graphic summarizes the current operating model from the ADW implementation, data model review, and data asset creation processes. It shows why the current path is rigorous but operationally heavy.</p>
    <section class="workflow-card" id="currentWorkflowCard"></section>

    <h2 class="section-title">Proposed Moirai Workflow by User Persona</h2>
    <p class="section-subtitle">Instead of forcing one generic view, this section shows the initial workflow for each persona separately. The distinct paths then collapse into the shared governed workflow once the request is structured and the platform takes over the repeated mechanics.</p>
    <section class="cascade-flow" id="cascadeFlow"></section>

    <h2 class="section-title">Process Walkthrough: Old vs New</h2>
    <p class="section-subtitle">This section makes the operational value explicit. It compares the current process to the Moirai process stage by stage and calls out where automation can replace repeated handoffs, SQL assembly, deployment mechanics, and fragmented governance work.</p>
    <section class="process-board" id="processBoard"></section>

    <h2 class="section-title">Expected Review Questions From Current ADW Owners</h2>
    <p class="section-subtitle">These are the likely pressure-test questions from the team that stood up and currently manages the old process. They are collapsed by default so the page stays focused, but they provide a checklist of risks to answer or close before treating Moirai as a replacement workflow.</p>
    <section class="questions-board" id="questionsBoard"></section>

    <p class="footer">Top: current workflow. Middle: persona-specific entry workflows cascading into the shared Moirai workflow. Bottom: value walkthrough and review-question checklist.</p>
  </div>

  <script>
    const currentWorkflow = {
      title: "Current ADW Workflow",
      note: "High manual coordination, multiple tools, explicit human signoffs",
      steps: [
        { n: 1, name: "Define Request", copy: "Create project plan, gather requirements, identify stakeholders, and align to release tracking and review expectations.", accent: "#ea580c", tag: "Manual coordination" },
        { n: 2, name: "Discover Existing Assets", copy: "Search ADW Catalog, legacy inventories, dependency tools, and prior documentation to determine what already exists.", accent: "#ea580c", tag: "Manual discovery" },
        { n: 3, name: "Design and Model Review", copy: "Create Confluence design artifacts, follow naming standards, schedule iterative design reviews, and obtain model feedback and signoff.", accent: "#ea580c", tag: "Manual review" },
        { n: 4, name: "Build Tables, Views, and Jobs", copy: "Create SQL, metadata-model entries, DDL, views, Airflow jobs, configs, and test cases across multiple repos and systems.", accent: "#ea580c", tag: "Manual build" },
        { n: 5, name: "Test in Dev and Staging", copy: "Run development and staging validation, inspect data manually, review metadata, document results, and update artifacts.", accent: "#ea580c", tag: "Manual validation" },
        { n: 6, name: "Create Deploy Ticket and Signoff", copy: "Open Jira implementation ticket, obtain SDLC approvals, coordinate with approver and executor, and prepare deployment instructions.", accent: "#ea580c", tag: "Manual approvals" },
        { n: 7, name: "Execute in Production", copy: "ADW admin or authorized executor triggers production actions, executes SQL or DAG steps, and records proof of execution.", accent: "#ea580c", tag: "Manual execution" },
        { n: 8, name: "Update Catalog and Trackers", copy: "Update metadata model, ADW Catalog, Confluence links, trackers, and release status so governance artifacts catch up with implementation.", accent: "#ea580c", tag: "Manual governance" }
      ]
    };

    const cascadeFlow = {
      title: "New Moirai Workflow: Entry Workflows Cascade Into Shared Delivery",
      note: "Different user workflows first, common delivery workflow second",
      entries: [
        {
          n: 1,
          title: "SQL Analyst Workflow",
