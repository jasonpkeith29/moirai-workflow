      const stepsRoot = root.querySelector('.workflow-steps');
      currentWorkflow.steps.forEach((step) => {
        const el = document.createElement('article');
        el.className = 'workflow-step current';
        el.style.setProperty('--step-accent', step.accent);
        el.innerHTML = `
          <div class="step-number">${step.n}</div>
          <div class="step-name">${step.name}</div>
          <div class="step-copy">${step.copy}</div>
          <div class="step-tag manual">${step.tag}</div>
        `;
        stepsRoot.appendChild(el);
      });
    }

